{
  "name": "test-your-gcp-knowledge",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "bin": {
    "test-your-gcp-knowledge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cd public && npm install && npm run build",
    "dev": "tsx watch src/server.ts",
    "test": "TMPDIR=/tmp vitest run src/__tests__",
    "start": "node dist/server.js",
    "cli": "tsx src/index.ts",
    "seed:remote": "bash data-generation/seed-remote.sh",
    "seed": "tsx data-generation/seed.ts",
    "db:list": "psql -d questions -c \"SELECT id, question, citations FROM questions;\"",
    "db:clean": "psql -d questions -c \"DELETE FROM questions WHERE id LIKE 'failure%' OR id LIKE 'error%';\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pg": "^8.11.11",
    "@types/jsdom": "^21.1.7",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^24.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@google/adk": "^0.3.0",
    "@google/genai": "^1.43.0",
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "firebase-admin": "^12.1.0",
    "google-auth-library": "^10.6.1",
    "hono": "^4.7.4",
    "pg": "^8.13.3",
    "tsx": "^4.21.0",
    "zod": "^3.24.2"
  }
}