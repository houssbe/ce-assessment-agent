# === Vertex AI (recommended for GCP users) ===
# GCP_PROJECT_ID=your-project-id
# GOOGLE_CLOUD_LOCATION=global

# === Standard Gemini API (alternative) ===
# GEMINI_API_KEY=your_api_key_here

# === Identity Platform / Firebase SSO ===
# FIREBASE_API_KEY=your-firebase-web-api-key

# === Server ===
# PORT=3000

# === Model override (optional) ===
# GEMINI_MODEL=gemini-3-flash-preview

# === Batch Generation ===
# QUESTIONS_PER_PLAY=2

# === Database Configuration ===
# INSTANCE_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=your_db_user
# DB_PASS=your_db_password
# DB_NAME=questions

# === Serverless VPC Access ===
# VPC_CONNECTOR=projects/your-project-id/locations/us-central1/connectors/your-connector
